<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>咖啡创业风险评估报告</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      line-height: 1.6;
      margin: 0;
      padding: 0;
      background-color: #f4f4f4;
    }
    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 20px;
    }
    header {
      background: #333;
      color: #fff;
      padding: 1rem;
      text-align: center;
    }
    .report-container {
      background: #fff;
      padding: 2rem;
      border-radius: 5px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
      margin-top: 2rem;
    }
    h2 {
      color: #333;
      margin-bottom: 1.5rem;
      border-bottom: 2px solid #6f4e37;
      padding-bottom: 0.5rem;
    }
    h3 {
      color: #6f4e37;
      margin-top: 1.5rem;
    }
    .risk-score {
      background: #f9f9f9;
      padding: 1.5rem;
      border-radius: 5px;
      text-align: center;
      margin-bottom: 2rem;
    }
    .risk-score h3 {
      margin-top: 0;
    }
    .score-value {
      font-size: 3rem;
      font-weight: bold;
      color: #4CAF50;
    }
    .score-value.medium {
      color: #ff9800;
    }
    .score-value.high {
      color: #f44336;
    }
    .section {
      margin-bottom: 2rem;
    }
    ul {
      list-style-type: none;
      padding: 0;
    }
    li {
      padding: 0.5rem 0;
      border-bottom: 1px solid #eee;
    }
    li:last-child {
      border-bottom: none;
    }
    .recommendations {
      background: #f0f8ff;
      padding: 1.5rem;
      border-radius: 5px;
    }
    .btn {
      display: inline-block;
      background: #4CAF50;
      color: #fff;
      padding: 10px 20px;
      text-decoration: none;
      border-radius: 5px;
      margin-top: 2rem;
      transition: background 0.3s;
    }
    .btn:hover {
      background: #45a049;
    }
  </style>
</head>
<body>
  <header>
    <h1>咖啡创业风险评估报告</h1>
  </header>
  
  <div class="container">
    <div class="report-container">
      <div class="risk-score">
        <h3>风险评分</h3>
        <div class="score-value <%= analysis.riskScore > 70 ? 'high' : analysis.riskScore > 40 ? 'medium' : '' %>">
          <%= analysis.riskScore %>/100
        </div>
        <p><%= analysis.riskScore > 70 ? '高风险' : analysis.riskScore > 40 ? '中等风险' : '低风险' %></p>
      </div>
      
      <div class="section">
        <h2>分析结果</h2>
        
        <h3>优势</h3>
        <ul>
          <% analysis.strengths.forEach(function(strength) { %>
            <li>• <%= strength %></li>
          <% }); %>
        </ul>
        
        <h3>劣势</h3>
        <ul>
          <% analysis.weaknesses.forEach(function(weakness) { %>
            <li>• <%= weakness %></li>
          <% }); %>
        </ul>
        
        <h3>机会</h3>
        <ul>
          <% analysis.opportunities.forEach(function(opportunity) { %>
            <li>• <%= opportunity %></li>
          <% }); %>
        </ul>
        
        <h3>威胁</h3>
        <ul>
          <% analysis.threats.forEach(function(threat) { %>
            <li>• <%= threat %></li>
          <% }); %>
        </ul>
      </div>
      
      <div class="section recommendations">
        <h3>改进建议</h3>
        <ul>
          <% analysis.recommendations.forEach(function(recommendation) { %>
            <li>• <%= recommendation %></li>
          <% }); %>
        </ul>
      </div>
      
      <a href="/" class="btn">返回首页</a>
    </div>
  </div>
</body>
</html>